# ── DealerSuite Frontend Environment Variables ───────────────────────────────
# Copy to .env.local for local development.
# In Railway: set as environment variables in the service settings.

# API base URL:
#   Local dev      → leave empty (Vite proxy forwards /api to localhost:8000)
#   Railway single-service (FastAPI serves React) → leave empty or set to ''
#   Railway separate-service (separate API URL)   → https://your-api.up.railway.app
VITE_API_URL=

VITE_APP_NAME=DealerSuite Loaner Inspection
