# ── DealerSuite Loaner Inspection — Backend Environment Variables ──────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env or service_account.json to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically.
# For local dev, create a Postgres DB and fill in your credentials.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dealersuite_loaner

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8-hour shift tokens

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Google Drive ──────────────────────────────────────────────────────────────
#
# SETUP (one-time):
#   1. https://console.cloud.google.com → new project (or existing)
#   2. Enable "Google Drive API" for the project
#   3. IAM & Admin → Service Accounts → Create Service Account
#      Give it "Editor" role (or a custom Drive role)
#   4. Keys → Add Key → JSON → download the file
#   5. In Google Drive, share the folder you want to use with the
#      service account email  (looks like name@project.iam.gserviceaccount.com)
#      and grant "Editor" permission.
#
# LOCAL DEV — place the downloaded JSON file in backend/ as service_account.json
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
#
# RAILWAY / PRODUCTION — base64-encode the JSON and set this var instead:
#   Linux/Mac:   base64 -w 0 service_account.json
#   PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("service_account.json"))
# GOOGLE_SERVICE_ACCOUNT_JSON=<your_base64_encoded_json_here>
#
# Root folder name in Drive where all inspection folders will be created:
GOOGLE_DRIVE_ROOT_FOLDER_NAME=DealerSuite Loaner Inspections

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
